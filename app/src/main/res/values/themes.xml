<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.MyApplication" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/fruit_primary</item>
        <item name="colorPrimaryContainer">@color/fruit_warning_bg</item>
        <item name="colorSecondary">@color/fruit_secondary</item>
        <item name="colorSecondaryContainer">@color/fruit_success_bg</item>
        <item name="colorSurface">@color/fruit_surface</item>
        <item name="android:colorBackground">@color/fruit_background_start</item>
        <item name="android:windowBackground">@color/fruit_background_start</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorOnSurface">@color/fruit_text_primary</item>
        <item name="android:textColorPrimary">@color/fruit_text_primary</item>
        <item name="android:textColorSecondary">@color/fruit_text_secondary</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="materialCardViewStyle">@style/FruitCardView</item>
        <item name="toolbarStyle">@style/FruitToolbar</item>
        <item name="textInputStyle">@style/FruitTextInputLayout</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="Theme.MyApplication" parent="Base.Theme.MyApplication" />

    <style name="FruitCardView" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/fruit_card</item>
        <item name="strokeColor">@color/fruit_border</item>
        <item name="strokeWidth">1dp</item>
        <item name="cardCornerRadius">24dp</item>
    </style>

    <style name="FruitToolbar" parent="Widget.Material3.Toolbar">
        <item name="titleTextColor">@color/fruit_text_primary</item>
        <item name="subtitleTextColor">@color/fruit_text_secondary</item>
        <item name="android:background">@android:color/transparent</item>
    </style>

    <style name="FruitTextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">20dp</item>
        <item name="boxCornerRadiusTopEnd">20dp</item>
        <item name="boxCornerRadiusBottomStart">20dp</item>
        <item name="boxCornerRadiusBottomEnd">20dp</item>
        <item name="boxStrokeColor">@color/fruit_border</item>
        <item name="hintTextColor">@color/fruit_text_secondary</item>
    </style>

    <style name="FruitImageShape">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">26dp</item>
    </style>

    <style name="FruitHeroImageShape">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">28dp</item>
    </style>
</resources>
